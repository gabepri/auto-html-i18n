[
  {
    "name": "malformed ICU pattern falls back to the original text when provided",
    "translated": "{0, plural, {broken}",
    "variables": [{ "value": "5", "type": "number" }],
    "locale": "es",
    "original": "5 items",
    "expected": "5 items"
  },
  {
    "name": "malformed ICU pattern without an original falls back to the raw pattern",
    "translated": "{0, plural, {broken}",
    "variables": [{ "value": "5", "type": "number" }],
    "locale": "es",
    "expected": "{0, plural, {broken}"
  },
  {
    "name": "fallback trims edge whitespace from the original for caller re-wrapping",
    "translated": "{0, plural, {broken}",
    "variables": [{ "value": "5", "type": "number" }],
    "locale": "es",
    "original": "  5 items \n",
    "expected": "5 items"
  },
  {
    "name": "valid ICU pattern evaluates normally and ignores the original fallback",
    "translated": "{0, plural, one {# oveja} other {# ovejas}}",
    "variables": [{ "value": "5", "type": "number" }],
    "locale": "es",
    "original": "5 sheep",
    "expected": "5 ovejas"
  },
  {
    "name": "fallback returns the original verbatim including its inline tags",
    "translated": "<a0>{0, plural, {broken}</a0>",
    "variables": [{ "value": "3", "type": "number" }],
    "tagAttributes": { "a0": { "href": "/items" } },
    "locale": "es",
    "original": "<a href=\"/items\">3 items</a>",
    "expected": "<a href=\"/items\">3 items</a>"
  },
  {
    "name": "pattern referencing a missing variable falls back to the original",
    "translated": "{0} tiene {1} gatos",
    "variables": [{ "value": "John", "type": "ignoreWord" }],
    "locale": "es",
    "original": "John has cats",
    "expected": "John has cats"
  },
  {
    "name": "pattern selecting on absent metadata falls back to the original",
    "translated": "{0_gender, select, female {ella compró} other {él compró}}",
    "variables": [{ "value": "Mary", "type": "ignoreWord" }],
    "locale": "es",
    "original": "Mary bought it",
    "expected": "Mary bought it"
  },
  {
    "name": "invalid region subtag degrades to base language rules",
    "translated": "{0, plural, one {# oveja} other {# ovejas}}",
    "variables": [{ "value": "5", "type": "number" }],
    "locale": "es-41",
    "original": "5 sheep",
    "expected": "5 ovejas"
  },
  {
    "name": "invalid region subtag keeps the base language singular rules",
    "translated": "{0, plural, one {# oveja} other {# ovejas}}",
    "variables": [{ "value": "1", "type": "number" }],
    "locale": "es-41",
    "original": "1 sheep",
    "expected": "1 oveja"
  },
  {
    "name": "underscore-style locale ids still evaluate",
    "translated": "{0, plural, one {# oveja} other {# ovejas}}",
    "variables": [{ "value": "5", "type": "number" }],
    "locale": "es_419",
    "original": "5 sheep",
    "expected": "5 ovejas"
  },
  {
    "name": "wholly invalid locales still render the translation via a universal fallback",
    "translated": "{0, plural, one {# oveja} other {# ovejas}}",
    "variables": [{ "value": "5", "type": "number" }],
    "locale": "419",
    "original": "5 sheep",
    "expected": "5 ovejas"
  }
]
