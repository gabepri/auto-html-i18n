{
  "name": "auto-dom-i18n",
  "version": "0.1.3",
  "description": "Zero-dependency, framework-agnostic translation library using MutationObserver for automatic DOM translation",
  "type": "module",
  "main": "./dist/auto-dom-i18n.cjs",
  "module": "./dist/auto-dom-i18n.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/auto-dom-i18n.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/auto-dom-i18n.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "i18n",
    "internationalization",
    "translation",
    "mutation-observer",
    "dom",
    "framework-agnostic"
  ],
  "author": "gabepri",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gabepri/auto-dom-i18n.git"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "happy-dom": "^16.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.1.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
